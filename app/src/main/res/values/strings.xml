    <string name="visitor_data_info_title">What is VISITOR_DATA?</string>
    <string name="visitor_data_info_intro">VISITOR_DATA is an identifier used by YouTube to track your session. When it\'s corrupted, it can cause:</string>
    <string name="visitor_data_info_problems">• Connectivity errors\n• Problems loading content\n• Search failures\n• Playback interruptions</string>
    <string name="visitor_data_info_solution">Resetting VISITOR_DATA generates a new identifier and usually resolves these issues.</string>
    <string name="visitor_data_info_note">This works for both anonymous users and users signed in.</string>
    <string name="visitor_data_info_confirm">Got it</string>

