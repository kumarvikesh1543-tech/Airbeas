<resources>

    <style name="Theme.AirBeats" parent="Theme.AppCompat.DayNight.NoActionBar">

        <!-- Completely transparent splash -->
        <item name="android:windowSplashScreenBackground">@android:color/transparent</item>

        <!-- Remove icon -->
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>

        <!-- Remove icon background -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/empty_splash</item>

        <!-- Disable preview -->
        <item name="android:windowDisablePreview">true</item>

    </style>

</resources>